---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { getCollection } from 'astro:content';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

// Get all blog posts
const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// Featured post (most recent)
const featuredPost = posts[0];
const recentPosts = posts.slice(1, 4);

// Blog categories with descriptions
const categories = [
  {
    id: 'agentic-ai',
    title: 'Agentic AI',
    description: 'Building autonomous agents and multi-step reasoning systems',
    icon: '⚙️',
    gradient: 'from-cyan-400 to-blue-500'
  },
  {
    id: 'ai-engineering',
    title: 'AI Engineering',
    description: 'Production AI systems, fine-tuning, and deployment strategies',
    icon: '🔬',
    gradient: 'from-purple-400 to-pink-500'
  },
  {
    id: 'business-automation',
    title: 'Business Automation',
    description: 'Workflow optimization and process automation with AI',
    icon: '⚡',
    gradient: 'from-amber-400 to-orange-500'
  },
  {
    id: 'seo-geo',
    title: 'SEO & GEO',
    description: 'Search optimization and geolocation-based strategies',
    icon: '📍',
    gradient: 'from-green-400 to-teal-500'
  },
];
---

<!doctype html>
<html lang="en" class="bg-background">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />

    <main class="mx-auto max-w-7xl px-4 py-16 flex-1 relative z-[1] w-full">
      
      <!-- Hero Section -->
      <section class="mb-24">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <!-- Left: Hero Text -->
          <div class="max-w-2xl">
            <div class="inline-flex items-center gap-2 border border-divider rounded-full px-3 py-1 mb-8 font-mono text-[12px] text-secondary">
              <span aria-hidden="true" class="block w-1.5 h-1.5 rounded-full bg-accent" style="animation: pulse-dot 2.4s ease-in-out infinite; box-shadow: 0 0 6px oklch(0.82 0.14 195 / 0.8);"></span>
              EXPERTISE VERIFIED
            </div>

            <h1 class="text-[42px] sm:text-[56px] lg:text-[64px] leading-[1.08] tracking-tight text-primary font-sans mb-6 text-balance">
              Advanced&nbsp;<span class="text-accent glow-accent">AI Systems</span>&nbsp;for Modern Builders
            </h1>
            
            <p class="text-[17px] sm:text-[18px] leading-[1.7] text-secondary mb-8 text-pretty max-w-[55ch]">
              Deep technical explorations into agentic AI, production engineering, business automation, and modern SEO/GEO strategies. Built for engineers and strategists.
            </p>

            <div class="flex flex-wrap gap-3">
              <a
                href="#featured"
                class="inline-flex items-center gap-2 rounded-md px-5 py-2.5 text-[14px] font-semibold font-mono transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent"
                style="background: var(--color-accent); color: oklch(0.10 0.012 260); box-shadow: 0 0 20px oklch(0.82 0.14 195 / 0.3);"
                onmouseover="this.style.boxShadow='0 0 32px oklch(0.82 0.14 195 / 0.5)'"
                onmouseout="this.style.boxShadow='0 0 20px oklch(0.82 0.14 195 / 0.3)'"
              >
                Explore articles
                <svg aria-hidden="true" width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
              <a
                href="/blog"
                class="inline-flex items-center gap-2 rounded-md border border-divider px-5 py-2.5 text-[14px] font-medium font-mono text-secondary hover:text-primary hover:border-accent transition-all duration-200"
              >
                View archive
              </a>
            </div>
          </div>

          <!-- Right: Featured/Visual -->
          <div class="relative hidden lg:block">
            <div class="absolute inset-0 rounded-[24px] blur-2xl opacity-30" style="background: linear-gradient(135deg, oklch(0.82 0.14 195), oklch(0.84 0.15 85));"></div>
            <div class="relative rounded-[24px] border border-divider p-8 overflow-hidden" style="background: var(--color-surface); backdrop-filter: blur(20px);">
              <div class="space-y-4">
                <div class="h-3 w-16 rounded bg-accent opacity-60"></div>
                <div class="h-3 w-full rounded bg-muted opacity-40"></div>
                <div class="h-3 w-full rounded bg-muted opacity-40"></div>
                <div class="h-3 w-24 rounded bg-muted opacity-40"></div>
                <div class="mt-6 pt-6 border-t border-divider">
                  <div class="h-3 w-20 rounded bg-accent-warm opacity-60"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Category Highlights -->
      <section class="mb-24">
        <div class="mb-12">
          <p class="text-[12px] font-mono text-accent tracking-widest uppercase mb-3">Topics</p>
          <h2 class="text-[32px] sm:text-[40px] leading-[1.1] tracking-tight text-primary font-sans text-balance">
            Four pillars of expertise
          </h2>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {categories.map((cat) => (
            <a
              href={`#${cat.id}`}
              class="card-glow group rounded-[16px] border border-divider p-6 transition-all duration-250 flex flex-col"
              style="background: var(--color-surface);"
            >
              <div class="text-4xl mb-4 opacity-80 group-hover:opacity-100 transition-opacity">{cat.icon}</div>
              <h3 class="text-[18px] font-semibold text-primary mb-2 leading-snug group-hover:text-accent transition-colors">
                {cat.title}
              </h3>
              <p class="text-[14px] text-secondary leading-relaxed flex-1">
                {cat.description}
              </p>
              <div class="flex items-center gap-1 mt-4 text-[13px] font-mono text-accent opacity-0 group-hover:opacity-100 transition-opacity duration-200">
                <span>Learn</span>
                <svg aria-hidden="true" width="12" height="12" viewBox="0 0 12 12" fill="none" class="transition-transform group-hover:translate-x-0.5">
                  <path d="M1 6h10M7 2l4 4-4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            </a>
          ))}
        </div>
      </section>

      <!-- Featured Post Section -->
      {featuredPost && (
        <section class="mb-24" id="featured">
          <div class="mb-8">
            <p class="text-[12px] font-mono text-accent-warm tracking-widest uppercase mb-3">Featured</p>
            <h2 class="text-[32px] sm:text-[40px] leading-[1.1] tracking-tight text-primary font-sans text-balance">
              Latest Article
            </h2>
          </div>

          <a
            href={`/blog/${featuredPost.id}/`}
            class="card-glow group rounded-[20px] border border-divider overflow-hidden transition-all duration-250 block"
            style="background: var(--color-surface);"
          >
            <div class="grid lg:grid-cols-2 gap-0">
              {featuredPost.data.heroImage && (
                <div class="overflow-hidden lg:order-2 aspect-[16/9] lg:aspect-auto lg:min-h-[340px]" style="background: var(--color-code-bg);">
                  <img
                    class="w-full h-full object-cover transition duration-500 group-hover:scale-[1.05]"
                    src={featuredPost.data.heroImage.src}
                    alt=""
                    aria-hidden="true"
                  />
                </div>
              )}
              <div class="flex flex-col justify-between p-8 lg:p-10">
                <div>
                  <p class="text-[12px] font-mono text-muted mb-3">
                    {featuredPost.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </p>
                  <h3 class="text-[28px] sm:text-[32px] font-semibold text-primary mb-4 leading-snug group-hover:text-accent transition-colors duration-200">
                    {featuredPost.data.title}
                  </h3>
                  {featuredPost.data.description && (
                    <p class="text-[15px] text-secondary leading-relaxed mb-6">
                      {featuredPost.data.description}
                    </p>
                  )}
                </div>
                <div class="flex items-center gap-2 text-[13px] font-mono text-accent">
                  <span>Read article</span>
                  <svg aria-hidden="true" width="12" height="12" viewBox="0 0 12 12" fill="none" class="transition-transform group-hover:translate-x-1">
                    <path d="M1 6h10M7 2l4 4-4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
              </div>
            </div>
          </a>
        </section>
      )}

      <!-- Recent Posts Grid -->
      {recentPosts.length > 0 && (
        <section class="mb-24">
          <div class="mb-8">
            <p class="text-[12px] font-mono text-accent tracking-widest uppercase mb-3">Recent</p>
            <h2 class="text-[32px] sm:text-[40px] leading-[1.1] tracking-tight text-primary font-sans text-balance">
              More articles
            </h2>
          </div>

          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6" role="list" aria-label="Recent blog posts">
            {recentPosts.map((post) => (
              <article role="listitem">
                <a
                  href={`/blog/${post.id}/`}
                  class="card-glow group flex flex-col gap-0 rounded-[16px] border border-divider overflow-hidden transition-all duration-250 h-full"
                  style="background: var(--color-surface);"
                  aria-label={`Read: ${post.data.title}`}
                >
                  {post.data.heroImage && (
                    <div class="overflow-hidden aspect-[16/9]" style="background: var(--color-code-bg);">
                      <img
                        class="w-full h-full object-cover transition duration-500 group-hover:scale-[1.03]"
                        src={post.data.heroImage.src}
                        alt=""
                        aria-hidden="true"
                      />
                    </div>
                  )}
                  <div class="flex flex-col gap-3 p-5 flex-1">
                    <p class="text-[12px] font-mono text-muted">
                      {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                    </p>
                    <h3 class="text-[16px] font-semibold text-primary tracking-tight leading-snug group-hover:text-accent transition-colors duration-200">
                      {post.data.title}
                    </h3>
                    {post.data.description && (
                      <p class="text-[14px] text-secondary leading-relaxed line-clamp-2 flex-1">
                        {post.data.description}
                      </p>
                    )}
                    <div class="flex items-center gap-1 pt-2 text-[13px] font-mono text-accent">
                      <span>Read more</span>
                      <svg aria-hidden="true" width="12" height="12" viewBox="0 0 12 12" fill="none" class="transition-transform duration-200 group-hover:translate-x-0.5">
                        <path d="M1 6h10M7 2l4 4-4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </div>
                  </div>
                </a>
              </article>
            ))}
          </div>

          <div class="text-center mt-12">
            <a
              href="/blog"
              class="inline-flex items-center gap-2 rounded-md border border-divider px-5 py-2.5 text-[14px] font-medium font-mono text-secondary hover:text-primary hover:border-accent transition-all duration-200"
            >
              View all articles
              <svg aria-hidden="true" width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        </section>
      )}

    </main>

    <Footer />
  </body>
</html>

<style>
  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.7); }
  }
</style>
