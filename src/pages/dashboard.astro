---
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="AI Writer Dashboard - Generate blog posts with Groq" />
    <title>AI Writer Dashboard</title>
  </head>
  <body>
    <Header />
    <main class="mx-auto max-w-4xl px-4 py-12">
      <div class="mb-8">
        <h1 class="text-4xl font-bold text-primary mb-2">AI Writer Dashboard</h1>
        <p class="text-secondary text-lg">Generate professional blog posts powered by Groq</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Generator Form -->
        <div class="lg:col-span-2">
          <form id="generatorForm" class="card-glow rounded-lg border border-accent border-opacity-20 bg-surface p-8">
            <!-- Topic Input -->
            <div class="mb-6">
              <label for="topic" class="block text-sm font-medium text-primary mb-2">
                Topic
              </label>
              <textarea
                id="topic"
                name="topic"
                placeholder="e.g., Building scalable multi-agent systems with LangGraph"
                required
                class="w-full px-4 py-3 rounded-lg bg-background border border-muted border-opacity-30 text-primary placeholder-muted focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent"
                rows="3"
              ></textarea>
            </div>

            <!-- Category Select -->
            <div class="mb-6">
              <label for="category" class="block text-sm font-medium text-primary mb-2">
                Category
              </label>
              <select
                id="category"
                name="category"
                required
                class="w-full px-4 py-3 rounded-lg bg-background border border-muted border-opacity-30 text-primary focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent"
              >
                <option value="">Select a category...</option>
                <option value="agentic-ai">Agentic AI</option>
                <option value="ai-engineering">AI Engineering</option>
                <option value="business-automation">Business Automation</option>
                <option value="seo-geo">SEO & Geo-Targeting</option>
              </select>
            </div>

            <!-- Style Select -->
            <div class="mb-6">
              <label for="style" class="block text-sm font-medium text-primary mb-2">
                Writing Style
              </label>
              <select
                id="style"
                name="style"
                class="w-full px-4 py-3 rounded-lg bg-background border border-muted border-opacity-30 text-primary focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent"
              >
                <option value="professional">Professional</option>
                <option value="technical">Technical</option>
                <option value="casual">Casual</option>
              </select>
            </div>

            <!-- Word Count -->
            <div class="mb-6">
              <label for="wordCount" class="block text-sm font-medium text-primary mb-2">
                Target Word Count
              </label>
              <input
                type="number"
                id="wordCount"
                name="wordCount"
                value="1500"
                min="500"
                max="5000"
                class="w-full px-4 py-3 rounded-lg bg-background border border-muted border-opacity-30 text-primary focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent"
              />
            </div>

            <!-- Publish Checkbox -->
            <div class="mb-8 flex items-center">
              <input
                type="checkbox"
                id="publish"
                name="publish"
                class="w-4 h-4 rounded border-muted cursor-pointer"
              />
              <label for="publish" class="ml-2 text-sm text-secondary">
                Auto-publish to blog
              </label>
            </div>

            <!-- Submit Button -->
            <button
              type="submit"
              id="submitBtn"
              class="w-full px-6 py-3 rounded-lg bg-accent text-background font-semibold hover:bg-accent-warm transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
            >
              Generate Post
            </button>
          </form>
        </div>

        <!-- Stats Sidebar -->
        <div class="lg:col-span-1">
          <div class="card-glow rounded-lg border border-accent-warm border-opacity-20 bg-surface p-6">
            <h3 class="text-lg font-semibold text-primary mb-4">Generation Info</h3>

            <div class="space-y-4">
              <div>
                <p class="text-xs text-muted uppercase tracking-wide">Status</p>
                <p id="statusText" class="text-primary font-medium mt-1">Ready</p>
              </div>

              <div>
                <p class="text-xs text-muted uppercase tracking-wide">Tokens Used</p>
                <p id="tokensText" class="text-accent font-mono text-lg mt-1">-</p>
              </div>

              <div>
                <p class="text-xs text-muted uppercase tracking-wide">Generation Time</p>
                <p id="timeText" class="text-primary font-mono mt-1">-</p>
              </div>

              <div class="mt-6 pt-6 border-t border-muted border-opacity-20">
                <p class="text-xs text-muted">Powered by Groq Mixtral 8x7B</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Results Section -->
      <div id="resultsSection" class="mt-12 hidden">
        <div class="card-glow rounded-lg border border-accent border-opacity-20 bg-surface p-8">
          <h2 class="text-2xl font-bold text-primary mb-4">Generated Post</h2>

          <div class="mb-6">
            <h3 id="resultTitle" class="text-xl font-semibold text-accent mb-2"></h3>
            <p id="resultDescription" class="text-secondary"></p>
          </div>

          <div class="mb-6">
            <h4 class="text-sm font-semibold text-primary uppercase mb-3">Preview</h4>
            <div id="resultPreview" class="prose prose-invert max-w-none rounded-lg bg-background p-4 text-secondary text-sm max-h-96 overflow-y-auto"></div>
          </div>

          <div class="flex gap-4">
            <button
              id="copyBtn"
              class="flex-1 px-6 py-3 rounded-lg bg-accent text-background font-semibold hover:bg-accent-warm transition-colors"
            >
              Copy Markdown
            </button>
            <button
              id="publishBtn"
              class="flex-1 px-6 py-3 rounded-lg border border-accent-warm bg-transparent text-accent-warm font-semibold hover:bg-accent-warm hover:bg-opacity-10 transition-colors"
            >
              Publish to Blog
            </button>
            <button
              id="newBtn"
              class="flex-1 px-6 py-3 rounded-lg bg-muted text-background font-semibold hover:bg-muted hover:bg-opacity-80 transition-colors"
            >
              Generate Another
            </button>
          </div>
        </div>
      </div>
    </main>
    <Footer />

    <style>
      :root {
        --color-background: oklch(0.10 0.012 260);
        --color-surface: oklch(0.145 0.018 260);
        --color-primary: oklch(0.96 0.005 220);
        --color-secondary: oklch(0.72 0.02 220);
        --color-muted: oklch(0.55 0.025 240);
        --color-accent: oklch(0.82 0.14 195);
        --color-accent-warm: oklch(0.84 0.15 85);
      }

      html {
        background-color: var(--color-background);
      }

      body {
        color: var(--color-primary);
        font-family: system-ui, -apple-system, sans-serif;
      }

      .text-primary {
        color: var(--color-primary);
      }

      .text-secondary {
        color: var(--color-secondary);
      }

      .text-muted {
        color: var(--color-muted);
      }

      .text-accent {
        color: var(--color-accent);
      }

      .text-accent-warm {
        color: var(--color-accent-warm);
      }

      .bg-background {
        background-color: var(--color-background);
      }

      .bg-surface {
        background-color: var(--color-surface);
      }

      .bg-accent {
        background-color: var(--color-accent);
      }

      .bg-accent-warm {
        background-color: var(--color-accent-warm);
      }

      .bg-muted {
        background-color: var(--color-muted);
      }

      .border-accent {
        border-color: var(--color-accent);
      }

      .border-accent-warm {
        border-color: var(--color-accent-warm);
      }

      .border-muted {
        border-color: var(--color-muted);
      }

      .card-glow {
        box-shadow: 0 0 20px rgba(209, 250, 229, 0.1);
        transition: box-shadow 0.3s;
      }

      .card-glow:hover {
        box-shadow: 0 0 30px rgba(209, 250, 229, 0.2);
      }

      .prose-invert {
        color: var(--color-secondary);
      }

      .prose-invert h1,
      .prose-invert h2,
      .prose-invert h3 {
        color: var(--color-accent);
      }

      .prose-invert code {
        background-color: var(--color-background);
        color: var(--color-accent);
        padding: 0.2em 0.4em;
        border-radius: 0.3em;
      }

      .prose-invert pre {
        background-color: var(--color-background);
        padding: 1em;
        border-radius: 0.5em;
        overflow-x: auto;
      }
    </style>

    <script>
      const form = document.getElementById('generatorForm') as HTMLFormElement
      const resultsSection = document.getElementById('resultsSection') as HTMLElement
      const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement
      const statusText = document.getElementById('statusText') as HTMLElement
      const tokensText = document.getElementById('tokensText') as HTMLElement
      const timeText = document.getElementById('timeText') as HTMLElement

      let currentGeneration: any = null

      form.addEventListener('submit', async (e) => {
        e.preventDefault()

        const formData = new FormData(form)
        const topic = formData.get('topic') as string
        const category = formData.get('category') as string
        const style = formData.get('style') as string
        const wordCount = parseInt(formData.get('wordCount') as string)
        const publish = (formData.get('publish') as any) === 'on'

        if (!topic || !category) {
          alert('Please fill in all required fields')
          return
        }

        submitBtn.disabled = true
        statusText.textContent = 'Generating...'

        try {
          const response = await fetch('/api/generate-post', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              topic,
              category,
              style,
              targetWordCount: wordCount,
              publish,
            }),
          })

          const data = await response.json()

          if (!response.ok) {
            throw new Error(data.error || 'Generation failed')
          }

          currentGeneration = data.post

          // Update stats
          statusText.textContent = publish ? 'Published!' : 'Generated'
          tokensText.textContent = data.post.tokensUsed.toLocaleString()
          timeText.textContent = `${data.post.generationTimeMs}ms`

          // Show results
          ;(document.getElementById('resultTitle') as HTMLElement).textContent = data.post.title
          ;(document.getElementById('resultDescription') as HTMLElement).textContent = data.post.description
          ;(document.getElementById('resultPreview') as HTMLElement).textContent = data.post.preview

          resultsSection.classList.remove('hidden')
          resultsSection.scrollIntoView({ behavior: 'smooth' })
        } catch (error) {
          statusText.textContent = 'Error'
          alert(error instanceof Error ? error.message : 'Generation failed')
        } finally {
          submitBtn.disabled = false
        }
      })

      document.getElementById('copyBtn')?.addEventListener('click', () => {
        if (currentGeneration) {
          navigator.clipboard.writeText(currentGeneration.preview)
          alert('Post preview copied to clipboard!')
        }
      })

      document.getElementById('publishBtn')?.addEventListener('click', async () => {
        if (currentGeneration && !currentGeneration.published) {
          // Regenerate with publish flag
          const formData = new FormData(form)
          formData.set('publish', 'on')
          form.dispatchEvent(new Event('submit'))
        }
      })

      document.getElementById('newBtn')?.addEventListener('click', () => {
        form.reset()
        resultsSection.classList.add('hidden')
        statusText.textContent = 'Ready'
        tokensText.textContent = '-'
        timeText.textContent = '-'
      })
    </script>
  </body>
</html>
