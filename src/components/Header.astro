---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="sticky top-0 z-50 border-b border-divider/60 backdrop-blur-xl bg-white/70">
	<nav class="mx-auto max-w-6xl px-4 h-14 flex items-center justify-between">
		<a href="/" class="text-[17px] font-semibold tracking-tight text-primary no-underline">
			{SITE_TITLE}
		</a>
		<div class="flex items-center gap-1">
			<HeaderLink href="/" class="px-3 py-1.5 text-[13px] font-medium text-secondary hover:text-primary">Home</HeaderLink>
			<HeaderLink href="/blog" class="px-3 py-1.5 text-[13px] font-medium text-secondary hover:text-primary">Blog</HeaderLink>
			<HeaderLink href="/about" class="px-3 py-1.5 text-[13px] font-medium text-secondary hover:text-primary">About</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header a {
		text-decoration: none;
	}
</style>
