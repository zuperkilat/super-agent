---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="sticky top-0 z-50 border-b border-divider backdrop-blur-xl" style="background: oklch(0.10 0.012 260 / 0.85);">
  <nav class="mx-auto max-w-6xl px-4 h-14 flex items-center justify-between" aria-label="Main navigation">
    <!-- Logo / Site title -->
    <a
      href="/"
      class="flex items-center gap-2 no-underline group"
      aria-label={SITE_TITLE + ' — Home'}
    >
      <!-- Tiny animated dot as a "live" indicator -->
      <span
        aria-hidden="true"
        class="block w-1.5 h-1.5 rounded-full bg-accent"
        style="box-shadow: 0 0 6px oklch(0.82 0.14 195 / 0.8); animation: pulse-dot 2.4s ease-in-out infinite;"
      ></span>
      <span class="text-[15px] font-semibold tracking-tight text-primary font-mono group-hover:text-accent transition-colors duration-200">
        {SITE_TITLE}
      </span>
    </a>

    <!-- Nav links -->
    <div class="flex items-center gap-1" role="list">
      <HeaderLink href="/" class="px-3 py-1.5 text-[13px] font-medium font-mono">Home</HeaderLink>
      <HeaderLink href="/blog" class="px-3 py-1.5 text-[13px] font-medium font-mono">Blog</HeaderLink>
      <HeaderLink href="/about" class="px-3 py-1.5 text-[13px] font-medium font-mono">About</HeaderLink>
    </div>
  </nav>
</header>

<style>
  header a {
    text-decoration: none;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.75); }
  }
</style>
